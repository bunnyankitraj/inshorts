    {
      "name": "🔥 Trending (Bonus)",
      "description": "GET /api/v1/trending\n\nReturns trending articles near the user's location.\n\nTrending Score = SUM[ event_weight × recency_decay ] × geo_proximity_boost\n  - event weights: view=1, click=3, share=5\n  - recency_decay = 1 / (1 + hours_since_event)\n  - geo_proximity_boost = 1 + (1 / (1 + distance_km))\n\nCached per geospatial cluster (2 decimal lat/lon = ~1.1km grid) with 5-min TTL.",
      "item": [
        {
          "name": "Trending — Mumbai",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/trending?lat=19.076&lon=72.877&limit=10",
              "host": ["{{baseUrl}}"],
