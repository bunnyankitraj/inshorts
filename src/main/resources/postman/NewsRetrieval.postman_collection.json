{
  "info": {
    "name": "Inshorts News Retrieval API",
    "description": "Minimal Postman collection for the APIs implemented in this Spring Boot project.\n\nBase URL: http://localhost:8080\n\nSetup:\n1. Start the app: JAVA_HOME=$(/usr/libexec/java_home -v 21) mvn spring-boot:run\n2. Optional: put GEMINI_API_KEY in .env for Gemini summaries and query analysis.\n\nThis collection intentionally includes only one request per implemented controller endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "inshorts-news-api-minimal-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "defaultLimit",
      "value": "5",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST /api/v1/query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Latest developments near Mumbai\",\n  \"userLat\": 19.0760,\n  \"userLon\": 72.8777,\n  \"radiusKm\": 50,\n  \"limit\": 5\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/query",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "query"
          ]
        },
        "description": "Natural language query endpoint. Uses Gemini when GEMINI_API_KEY is configured; otherwise falls back to simple routing/search behavior."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/category",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/category?category=sports&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "category"
          ],
          "query": [
            {
              "key": "category",
              "value": "sports"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles by category, ranked by publication date descending."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/score",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/score?threshold=0.7&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "score"
          ],
          "query": [
            {
              "key": "threshold",
              "value": "0.7"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles with relevance_score greater than or equal to threshold."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/search?query=IPL 2025&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "search"
          ],
          "query": [
            {
              "key": "query",
              "value": "IPL 2025"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Search article title and description text."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/source",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/source?source=Reuters&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "source"
          ],
          "query": [
            {
              "key": "source",
              "value": "Reuters"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles from a source, ranked by publication date descending."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/nearby",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/nearby?lat=19.076&lon=72.877&radius=50&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "nearby"
          ],
          "query": [
            {
              "key": "lat",
              "value": "19.076"
            },
            {
              "key": "lon",
              "value": "72.877"
            },
            {
              "key": "radius",
              "value": "50"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles within radius km of the given latitude/longitude."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/trending",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/trending?lat=19.076&lon=72.877&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "trending"
          ],
          "query": [
            {
              "key": "lat",
              "value": "19.076"
            },
            {
              "key": "lon",
              "value": "72.877"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Bonus endpoint. Fetch location-based trending articles from seeded user event data."
      },
      "response": []
    }
  ]
}
