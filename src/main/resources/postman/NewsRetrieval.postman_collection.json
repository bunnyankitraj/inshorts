{
  "info": {
    "name": "Inshorts News Retrieval API",
    "description": "Postman collection for the APIs implemented in this Spring Boot project.\n\nBase URL: http://localhost:8080\n\nSetup:\n1. Start the app: JAVA_HOME=$(/usr/libexec/java_home -v 21) mvn spring-boot:run\n2. Optional: put OPENAI_API_KEY in .env for OpenAI-generated summaries and query analysis. Without it, summaries fall back to a truncated description and /query falls back to a plain text search.\n\nPagination: every list endpoint accepts `page` (1-based, default 1) and `limit` (page size, 1-50, default 5). For POST /query, pass `page`/`limit` in the body. Response metadata reports `totalResults`, `page`, `pageSize`, and `totalPages`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "inshorts-news-api-v2"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "defaultPage",
      "value": "1",
      "type": "string"
    },
    {
      "key": "defaultLimit",
      "value": "5",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST /api/v1/query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Latest developments near Mumbai\",\n  \"userLat\": 19.0760,\n  \"userLon\": 72.8777,\n  \"radiusKm\": 50,\n  \"page\": 1,\n  \"limit\": 5\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/query",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "query"
          ]
        },
        "description": "Natural language query endpoint. Uses OpenAI (gpt-4o-mini) when OPENAI_API_KEY is configured to extract entities + intent and route to a retrieval strategy; otherwise falls back to a plain text search. Supports `page`/`limit` in the body for pagination."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/category",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/category?category=sports&page={{defaultPage}}&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "category"
          ],
          "query": [
            {
              "key": "category",
              "value": "sports"
            },
            {
              "key": "page",
              "value": "{{defaultPage}}"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles by category, ranked by publication date descending. Paginated (page/limit). Try page=2 to see the next page."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/score",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/score?threshold=0.7&page={{defaultPage}}&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "score"
          ],
          "query": [
            {
              "key": "threshold",
              "value": "0.7"
            },
            {
              "key": "page",
              "value": "{{defaultPage}}"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles with relevance_score greater than or equal to threshold, ranked by score descending. Paginated (page/limit)."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/search?query=IPL 2025&page={{defaultPage}}&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "search"
          ],
          "query": [
            {
              "key": "query",
              "value": "IPL 2025"
            },
            {
              "key": "page",
              "value": "{{defaultPage}}"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Search article title and description text, ranked by a blend of relevance_score and text match. Paginated over a capped candidate set (news.search.candidate-cap)."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/source",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/source?source=Reuters&page={{defaultPage}}&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "source"
          ],
          "query": [
            {
              "key": "source",
              "value": "Reuters"
            },
            {
              "key": "page",
              "value": "{{defaultPage}}"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles from a source (exact, case-insensitive), ranked by publication date descending. Paginated (page/limit)."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/news/nearby",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/news/nearby?lat=19.076&lon=72.877&radius=50&page={{defaultPage}}&limit={{defaultLimit}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "news",
            "nearby"
          ],
          "query": [
            {
              "key": "lat",
              "value": "19.076"
            },
            {
              "key": "lon",
              "value": "72.877"
            },
            {
              "key": "radius",
              "value": "50"
            },
            {
              "key": "page",
              "value": "{{defaultPage}}"
            },
            {
              "key": "limit",
              "value": "{{defaultLimit}}"
            }
          ]
        },
        "description": "Fetch articles within radius km of the given latitude/longitude, ranked by distance (closest first). Each article includes distance_km. Paginated (page/limit)."
      },
      "response": []
    },
    {
      "name": "GET /api/v1/trending",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/trending?lat=19.076&lon=72.877&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "trending"
          ],
          "query": [
            {
              "key": "lat",
              "value": "19.076"
            },
            {
              "key": "lon",
              "value": "72.877"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Bonus endpoint. Location-based trending feed from seeded user event data, cached per geo-cluster (5-min TTL). Returns a single capped feed (no page param)."
      },
      "response": []
    }
  ]
}
